{
  "expo": {
    "name": "منصة إدارة وسائل التواصل",
    "slug": "social-media-manager",
    "version": "1.0.1",
    "scheme": "social-media-manager",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",

    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "تحتاج التطبيق إلى الوصول إلى صورك لرفع المحتوى.",
          "cameraPermission": "تحتاج التطبيق إلى الكاميرا لالتقاط الصور ومقاطع الفيديو."
        }
      ]
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.socialmanager.app"
    },

    "android": {
      "package": "com.socialmanager.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0C0820"
      },
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },

    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single",
      "name": "منصة المحتوى",
      "shortName": "المحتوى",
      "description": "أدِر جميع حساباتك على وسائل التواصل من مكان واحد",
      "themeColor": "#06B6D4",
      "backgroundColor": "#0C0820",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/",
      "scope": "/",
      "lang": "ar",
      "dir": "rtl"
    },

    "experiments": {
      "typedRoutes": true,
      "baseUrl": ""
    },

    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
